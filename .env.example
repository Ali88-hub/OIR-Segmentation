# Copy this file to .env and fill in your values

# Required — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — get from https://www.ncbi.nlm.nih.gov/account/
# Increases PubMed rate limit from 3 req/s to 10 req/s
NCBI_API_KEY=

# Required by NCBI (any valid email)
NCBI_EMAIL=your@email.com

# Optional — if set, protects /ask and /ingest endpoints with a static API key
# Callers must pass: X-Api-Key: <value> header
API_KEY=
